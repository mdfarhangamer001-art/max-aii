# ========================================================
# TEHZEEB AI OS - PORTABLE LOCAL CONFIGURATION TEMPLATE
# ========================================================

# GEMINI_API_KEY: Standard Google Gemini API Key for general reasoning and media processing
GEMINI_API_KEY=""

# OMNI_API_KEY: Key for custom Omni routes, OpenRouter, or other large language model proxies
OMNI_API_KEY=""

# OMNI_API_URL: Custom endpoint route for the Omni model (Defaults to standard model gateway if empty)
OMNI_API_URL="https://api.openrouter.ai/v1"

# OMNI_MODEL_NAME: Selected fallback model for secure offline/hybrid queries
OMNI_MODEL_NAME="google/gemini-3.5-flash"

# APP_URL: The hosting URL (Defaults to http://localhost:3000 when running locally)
APP_URL="http://localhost:3000"

# GITHUB_CLIENT_ID: Optional integration variables for custom local backups
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# SECURITY_SALT: Secret salt used for local AES-256 Android pairing key encryption
SECURITY_SALT="TEHZEEB_SECURE_SALT_9901X"
